SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# MySQL 컨테이너 초기화 값이다.
# docker-compose에서 mysql 서비스를 띄울 때 사용한다.
MYSQL_PORT=3306
MYSQL_DATABASE=domisa
MYSQL_USER=domisa
MYSQL_PASSWORD=domisa1234
MYSQL_ROOT_PASSWORD=root1234

# 백엔드가 실제로 접속할 DB 주소다.
# 로컬에서 앱을 IDE로 실행하면 localhost:3306/domisa
# docker-compose에서 백엔드까지 같이 띄우면 mysql:3306/domisa
DB_URL=localhost:3306/domisa
DB_USERNAME=domisa
DB_PASSWORD=domisa1234
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# JWT
JWT_SECRET=local-jwt-secret-change-me

# Frontend / Cookie
FRONTEND_URL=http://localhost:3000
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_AUTH_COOKIE_DOMAIN=

# AWS S3
AWS_S3_BUCKET=
AWS_REGION=ap-northeast-2
AWS_S3_UPLOAD_PREFIX=uploads
AWS_S3_PRESIGNED_URL_EXPIRATION=PT10M

# Profile image processing
PROFILE_IMAGE_FIXED_DELAY_MS=30000
PROFILE_IMAGE_THUMBNAIL_SIZE=300
PROFILE_IMAGE_ORIGIN_MAX_SIZE=1080
PROFILE_IMAGE_THUMBNAIL_BLUR_KERNEL_SIZE=13
PROFILE_IMAGE_ORIGIN_BLUR_KERNEL_SIZE=17
PROFILE_IMAGE_BATCH_SIZE=10
PROFILE_IMAGE_MAX_RETRY_COUNT=5
